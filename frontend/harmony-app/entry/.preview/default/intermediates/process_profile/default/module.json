{
	"app": {
		"bundleName": "com.visitor.servicesystem",
		"vendor": "team-project",
		"versionCode": 1000000,
		"versionName": "1.0.0",
		"icon": "$media:layered_image",
		"label": "$string:app_name",
		"apiReleaseType": "Release",
		"compileSdkVersion": "6.0.2.130",
		"targetAPIVersion": 60002022,
		"minAPIVersion": 60002022,
		"compileSdkType": "HarmonyOS",
		"targetMinorAPIVersion": 0,
		"targetPatchAPIVersion": 0,
		"appEnvironments": [],
		"bundleType": "app",
		"buildMode": "debug",
		"debug": true
	},
	"module": {
		"name": "entry",
		"type": "entry",
		"description": "$string:module_desc",
		"mainElement": "EntryAbility",
		"deviceTypes": [
			"phone"
		],
		"deliveryWithInstall": true,
		"pages": "$profile:main_pages",
		"requestPermissions": [
			{
				"name": "ohos.permission.INTERNET"
			}
		],
		"abilities": [
			{
				"name": "EntryAbility",
				"srcEntry": "./ets/entryability/EntryAbility.ets",
				"description": "$string:entryability_desc",
				"icon": "$media:layered_image",
				"label": "$string:app_name",
				"startWindowIcon": "$media:layered_image",
				"startWindowBackground": "$color:start_window_background",
				"visible": true
			},
			{
				"name": "FakeUIAbility",
				"srcEntry": "../../.preview/fakeuiability/FakeUIAbility.ets",
				"startWindowIcon": "startIcon",
				"startWindowBackground": "#FFFFFF"
			}
		],
		"packageName": "entry",
		"installationFree": false,
		"virtualMachine": "ark13.0.1.0",
		"compileMode": "esmodule",
		"dependencies": []
	}
}
